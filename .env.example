# Get this from Neon: Project > Dashboard > Connection string
# Use the pooled connection string for serverless deployments.
DATABASE_URL="postgresql://user:password@ep-example.region.aws.neon.tech/theboys?sslmode=require"

# Optional but recommended for migrations. Use the direct Neon host, not the pooled host.
# If this is omitted, drizzle.config.ts derives it from DATABASE_URL by removing "-pooler".
DIRECT_DATABASE_URL="postgresql://user:password@ep-example.region.aws.neon.tech/theboys?sslmode=verify-full"

# Get this from Neon: Project > Auth > Configuration > Auth Base URL
PUBLIC_NEON_AUTH_URL="https://ep-example.neonauth.us-east-2.aws.neon.build/neondb/auth"

# Used to keep browser auth/app caches separate between local dev and prod.
PUBLIC_APP_ENV="development"

# Optional. Free tier at https://the-odds-api.com/ — enables live AU bookmaker odds on the tips page.
THE_ODDS_API_KEY=""

# Local development can use .env.development with the same keys pointed at your
# Neon development branch. .env* files are ignored by git.
